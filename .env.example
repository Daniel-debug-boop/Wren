# ═══════════════════════════════════════════════════════════════
#  WREN — Environment Configuration Template
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Wren reads variables from .env automatically when running locally.
# ═══════════════════════════════════════════════════════════════

# ── LLM Configuration ─────────────────────────────────────────
# Your primary LLM API key (OpenAI, Anthropic, etc.)
# LLM_API_KEY="sk-..."
#
# LLM model to use (default: gpt-4o)
# LLM_MODEL="gpt-4o"
#
# Custom API base URL (for non-OpenAI providers like OpenRouter)
# LLM_BASE_URL="https://openrouter.ai/api/v1"

# ── App Builder ───────────────────────────────────────────────
# Default output directory for generated projects
# APP_BUILDER_OUTPUT="./wren-generations"
#
# Maximum tokens per LLM request
# APP_BUILDER_MAX_TOKENS=16384
#
# Temperature for generation (0.0 - 1.0)
# APP_BUILDER_TEMPERATURE=0.2

# ── Backend Server ────────────────────────────────────────────
# Host address to bind the server to
# BACKEND_HOST="0.0.0.0"
#
# Port for the backend server
# BACKEND_PORT=8000

# ── Frontend ──────────────────────────────────────────────────
# Backend API URL (used by the frontend)
# VITE_BACKEND_HOST="http://localhost:8000"
#
# Enable TLS (HTTPS) for the frontend
# VITE_USE_TLS=false
#
# Insecure skip verify (for self-signed certs in development)
# VITE_INSECURE_SKIP_VERIFY=false
#
# Frontend dev server port
# VITE_FRONTEND_PORT=5173

# ── Android ───────────────────────────────────────────────────
# Backend URL for the Android app to connect to
# WREN_BACKEND_URL="http://10.0.2.2:8000"  # Android emulator localhost
#
# API key for the Android app
# WREN_API_KEY="sk-..."

# ── Advanced / Debug ──────────────────────────────────────────
# Enable verbose logging
# WREN_DEBUG=false
#
# Log level (DEBUG, INFO, WARNING, ERROR)
# WREN_LOG_LEVEL="INFO"
#
# Disable colored terminal output
# WREN_NO_COLOR=false
